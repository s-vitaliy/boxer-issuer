BOXER__INSTANCE_NAME=test
BOXER__INIT__BACKEND_TYPE=Kubernetes
BOXER__BACKEND__KUBERNETES__EXEC=kind get kubeconfig --name kind
BOXER__BACKEND__KUBERNETES__LEASE_NAME=boxer-test-lease
BOXER__BACKEND__KUBERNETES__LEASE_DURATION=2m
BOXER__BACKEND__KUBERNETES__LEASE_RENEW_DURATION=1m
BOXER__BACKEND__KUBERNETES__NAMESPACE=default
BOXER__BACKEND__KUBERNETES__LABEL_SELECTOR_KEY=app.kubernetes.io/name
BOXER__BACKEND__KUBERNETES__LABEL_SELECTOR_VALUE=boxer.sneaksanddata.com

